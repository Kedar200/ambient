<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow effect layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#20EF4444" />
            <corners android:radius="32dp" />
            <padding
                android:bottom="2dp"
                android:left="2dp"
                android:right="2dp"
                android:top="2dp" />
        </shape>
    </item>
    
    <!-- Mid glow layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#30EF4444" />
            <corners android:radius="30dp" />
            <padding
                android:bottom="1dp"
                android:left="1dp"
                android:right="1dp"
                android:top="1dp" />
        </shape>
    </item>
    
    <!-- Glass effect background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#90303030"
                android:centerColor="#80282828"
                android:endColor="#70202020"
                android:type="linear" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#40EF4444" />
        </shape>
    </item>
    
    <!-- Inner highlight for glass effect -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#20FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00000000"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>